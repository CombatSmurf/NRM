          </constraints>
          <selectionEntries>
            <selectionEntry id="ab79-6ad9-501f-fdfb" name="Strongman" page="0" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="26d3-4bb0-88e5-f585" type="max"/>
                <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="83fd-8c54-12b3-5ae5" type="min"/>
              </constraints>
              <rules>
                <rule id="cfd9-fa37-6dc4-2cce" name="Strongman" page="0" hidden="false">
                  <description>He may use a double-handed weapon without the usual penalty of always striking last. Work out order of battle as you would with other weapons</description>
                </rule>
              </rules>
              <costs>
                <cost name="pts" typeId="points" value="0"/>
                <cost name="Warband Rating" typeId="wb-rating" value="0"/>
              </costs>
            </selectionEntry>
            <selectionEntry id="e927-fca6-5139-c3c5" name="Unstoppable Charge" page="0" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="806c-2a48-f902-5f0e" type="max"/>
                <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5acd-cfa1-b3c2-de40" type="min"/>
              </constraints>
              <rules>
                <rule id="45b5-d154-7e36-8d5b" name="Unstoppable Charge" page="0" hidden="false">
                  <description>When he charges, the warrior is almost impossible to halt. He adds +1 to his Weapon Skill when charging.</description>
                </rule>
              </rules>
              <costs>
                <cost name="pts" typeId="points" value="0"/>
                <cost name="Warband Rating" typeId="wb-rating" value="0"/>
              </costs>
            </selectionEntry>
            <selectionEntry id="f54c-8713-2e34-5c9e" name="Combat Master" page="0" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="674e-4ac6-7347-b9cc" type="max"/>
                <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="08e0-5236-4f48-4ead" type="min"/>
              </constraints>
              <rules>
                <rule id="8da9-0b85-fe75-56d0" name="Combat Master" page="0" hidden="false">
                  <description>When fighting multiple opponents in hand-to-hand combat,  he gains an extra Attack in any hand to hand phase . In addition, the warrior is immune to ‘All Alone’ tests.</description>
                </rule>
              </rules>
              <costs>
                <cost name="pts" typeId="points" value="0"/>
                <cost name="Warband Rating" typeId="wb-rating" value="0"/>
              </costs>
            </selectionEntry>
          </selectionEntries>

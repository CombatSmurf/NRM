      <rules>
        <rule id="9b29-a5e0-e77b-ea41" name="Not a Fighter" hidden="false">
          <description>If a Human Scout is taken Out of Action during a game, he decides to leave on a 1-3, instead of the normal 1-2 when rolling for injury at the end of the game.</description>
        </rule>
        <rule id="ff6e-310a-786b-1d92" name="Human Scout" hidden="false">
          <description>Upkeep +5gc
Rating +9pts (+1/exp)
May be Hired: Any warband except Orcs, Goblins, Beastmen or Possessed may hire the Human Scout.</description>
        </rule>
      </rules>

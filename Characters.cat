                <selectionEntry id="ff0e-c7a5-b930-93dd" name="Luck" hidden="false" collective="false" import="true" type="upgrade">
                  <rules>
                    <rule id="b26f-f4f3-b5b0-d196" name="Luck" hidden="false">
                      <description>The Elf Ranger is blessed by Lileath, the Elven goddess of luck. Once per game he may re-roll any dice roll he makes (but not one made by other members of the warband).</description>
                    </rule>
                  </rules>
                  <costs>

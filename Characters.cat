      <rules>
        <rule id="426d-1196-a630-8fac" name="Dark Elf Assassin" hidden="false">
          <description>Upkeep: 25gc
Rating: +25pts (+1/exp)
May be hired: Any evil warband may hire a Dark Elf Assassin.</description>
        </rule>
        <rule id="da4e-9fee-a275-c688" name="Excellent Sight" hidden="false">
          <description>The Elf spots Hidden enemies from two times as far away as other warriors (ie, twice his Initiative value in inches).</description>
        </rule>
        <rule id="82cd-4a34-4d87-8733" name="Perfect Killer" hidden="false">
          <description>All attacks made by the Assassin, whether in shooting or close combat, have an extra -1 save modifier to represent his skill in striking at unarmoured spots.</description>
        </rule>
        <rule id="13f5-5ff6-5db6-9c82" name="Kindred Hatred" hidden="false">
          <description>The Dark Elves have been fighting the High Elves for many centuries. The wars between these two races have been very long and bloody affairs. Dark Elves Hate any High Elf warriors including High Elf Hired Swords.</description>
        </rule>
      </rules>

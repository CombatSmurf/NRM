      <rules>
        <rule id="7a9b-6c5b-4c6a-6887" name="Cook" hidden="false">
          <description>Halflings are renowned for their cooking skills. A warband with a Halfling Scout may increase its maximum size by +1, as warriors from all around are attracted by the smell of great food!
Note that this does not increase the maximum number of Heroes you may have.</description>
        </rule>
        <rule id="c70f-7f36-56f0-01b8" name="Halfling Scout" hidden="false">
          <description>Upkeep +5gc
Rating +5pts (+1/exp)
May be Hired: Any warband except Skaven, Undead and the Possessed may hire a Halfling Scout.</description>
        </rule>
      </rules>

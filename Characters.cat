          <selectionEntries>
            <selectionEntry type="upgrade" import="true" name="Heavy Fur Coat" hidden="false" id="4c15-0306-fcd5-d57b">
              <profiles>
                <profile name="Heavy Fur Coat" typeId="94239014-ea28-23eb-4142-f492dc4caf17" typeName="Armor" hidden="false" id="f47b-1c56-244b-9cc4">
                  <characteristics>
                    <characteristic name="Armor Save" typeId="26f1ea4e-6017-a8fa-db2b-5c2a83aea46b">5+/6+</characteristic>
                    <characteristic name="Special" typeId="ff797ec4-8d7e-cab1-656e-896ae3ed005f">5+ Armor Save vs Ranged, 6+ Armor Save vs Melee</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <constraints>
                <constraint type="min" value="1" field="selections" scope="parent" shared="false" id="514c-05fa-f112-8299" percentValue="false" includeChildSelections="false" includeChildForces="false"/>

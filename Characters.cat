              </constraints>
              <costs>
                <cost name="pts" typeId="points" value="0"/>
              </costs>
            </entryLink>
            <entryLink id="19c9-d9ea-9920-0861" name="Rapier" hidden="false" collective="false" import="true" targetId="1cad-3ea5-f379-1040" type="selectionEntry">
              <constraints>
                <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c014-7c93-1d54-1e4a" type="min"/>
              </constraints>
              <costs>
                <cost name="pts" typeId="points" value="0"/>

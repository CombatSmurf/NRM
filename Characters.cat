              <selectionEntries>
                <selectionEntry id="0a11-1b3e-fb89-0d76" name="Ferocious Charge" hidden="false" collective="false" import="true" type="upgrade">
                  <rules>
                    <rule id="e1db-658e-4c16-a49a" name="Ferocious Charge" hidden="false">
                      <description>The Dwarf may double his attacks on the turn in which he charges.
He will suffer a -1 to hit penalty on that turn.</description>
                    </rule>
                  </rules>
                  <costs>
                    <cost name="pts" typeId="points" value="0"/>
                    <cost name="Warband Rating" typeId="wb-rating" value="0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="1899-524d-b70c-dffb" name="Monster Slayer" hidden="false" collective="false" import="true" type="upgrade">
                  <rules>
                    <rule id="1f27-2c11-a47e-3a0d" name="Monster Slayer" hidden="false">
                      <description>The Troll Slayer always wounds any opponent on a D6 roll of 4+, regardless of Toughness, unless his own Strength (with weapon modifiers) would mean that a lower result than this is needed.</description>
                    </rule>
                  </rules>
                  <costs>
                    <cost name="pts" typeId="points" value="0"/>
                    <cost name="Warband Rating" typeId="wb-rating" value="0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="6d3b-25b0-a352-7060" name="Berserker" hidden="false" collective="false" import="true" type="upgrade">
                  <rules>
                    <rule id="1ae3-432a-f08f-f55a" name="Berserker" hidden="false">
                      <description>The Dwarf may add +1 to his to hit rolls during the turn in which he charges.</description>
                    </rule>
                  </rules>
                  <costs>
                    <cost name="pts" typeId="points" value="0"/>
                    <cost name="Warband Rating" typeId="wb-rating" value="0"/>
                  </costs>
                </selectionEntry>
              </selectionEntries>
            </selectionEntryGroup>
          </selectionEntryGroups>

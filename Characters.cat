              <rules>
                <rule name="Expert Hunter" id="aa3e-68f9-ac07-4621" hidden="false">
                  <description>A Human Scout that has been declared as Hidden may only be detected by models within half their Initiative value in inches, not their Initiative value as normal.
In addition, a Human Scout may fire his Bow without giving away his position (he may fire and remain Hidden).</description>
                </rule>
              </rules>

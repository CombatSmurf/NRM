                  <rules>
                    <rule id="ba33-1f69-726b-9632" name="Fey" hidden="false">
                      <description>Hostile magic spells will not affect the Elf on a D6 roll of 4+.</description>
                    </rule>
                  </rules>
                  <costs>
                    <cost name="pts" typeId="points" value="0"/>
                    <cost name="Warband Rating" typeId="wb-rating" value="0"/>
                  </costs>

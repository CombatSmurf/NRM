            <characteristic name="T" typeId="54f4796b-dedb-c296-8b1a-ff7f8043293a">3(2)</characteristic>
            <characteristic name="W" typeId="3172c8dc-ebe4-0c40-72ab-8fd0076b9442">1</characteristic>

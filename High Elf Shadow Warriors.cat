          </costs>
        </selectionEntry>
        <selectionEntry id="5569-9bb7-0dd3-8286" name="Shooting Skills" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="807c-f9c3-ae37-f01e" type="max"/>
          </constraints>
          <entryLinks>
            <entryLink id="d9b8-be65-537c-8c8d" name="Shooting Skills" hidden="false" collective="false" import="true" targetId="52007ee0-cc99-b312-3650-cfab391e476c" type="selectionEntryGroup"/>
          </entryLinks>

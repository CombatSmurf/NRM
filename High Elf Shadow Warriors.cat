        <selectionEntry id="9f7d41cd-13db-b929-0b5e-8b2cfbe8ca02" name="Skills" page="0" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="minSelections" type="min"/>
            <constraint field="selections" scope="parent" value="1" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="maxSelections" type="max"/>
          </constraints>
          <selectionEntryGroups>
            <selectionEntryGroup id="46418e2d-9527-1f04-56ea-dd40f645fdd7" name="Strength Skills (only with Powerful build skill)" hidden="false" collective="false" import="true">
              <selectionEntries>
                <selectionEntry id="ca815c66-ef57-7279-c83e-0278c3c51e56" name="Mighty Blow" page="0" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="parent" value="1" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="maxSelections" type="max"/>
                  </constraints>
                  <rules>
                    <rule id="7f7024dc-3313-6218-981e-77f88e13173c" name="Mighty Blow" page="0" hidden="false">
                      <description>The warrior knows how to use his strength to maximum effect and has a +1 Strength bonus in close combat (excluding pistols). As his
Strength is used for close combat weapons, the bonus applies to all such weapons.</description>
                    </rule>
                  </rules>
                  <costs>
                    <cost name="pts" typeId="points" value="0"/>
                    <cost name="Warband Rating" typeId="wb-rating" value="0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="a51b1363-6b17-9d11-51dd-f1dae850608f" name="Pit Fighter" page="0" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="parent" value="1" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="maxSelections" type="max"/>
                  </constraints>
                  <rules>
                    <rule id="2063d199-a54e-55d8-6a63-4525aaf39864" name="Pit Fighter" page="0" hidden="false">
                      <description>The warrior has learned how to fight in enclosed spaces from his time in the dangerous fighting pits of the Empire. He is an expert at fighting in confined areas and adds +1 to his WS and +1 to his Attacks if he is fighting inside buildings or ruins.</description>
                    </rule>
                  </rules>
                  <costs>
                    <cost name="pts" typeId="points" value="0"/>
                    <cost name="Warband Rating" typeId="wb-rating" value="0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="addae651-3944-ee2d-3445-8a79cf7be625" name="Resilient" page="0" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="parent" value="1" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="maxSelections" type="max"/>
                  </constraints>
                  <rules>
                    <rule id="899d11fc-d3a9-7025-e8e4-ddb4b130cadc" name="Resilient" page="0" hidden="false">
                      <description>Deduct -1 Strength from all hits against him in close combat. This does not affect armour save modifiers</description>
                    </rule>
                  </rules>
                  <costs>
                    <cost name="pts" typeId="points" value="0"/>
                    <cost name="Warband Rating" typeId="wb-rating" value="0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="0c2e2814-c6c5-5436-4683-3aa132dbde7e" name="Fearsome" page="0" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="parent" value="1" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="maxSelections" type="max"/>
                  </constraints>
                  <rules>
                    <rule id="bc4de587-1ff4-1440-4360-f6a2497cfa35" name="Fearsome" page="0" hidden="false">
                      <description>The model that he causes fear in opposing models</description>
                    </rule>
                  </rules>
                  <costs>
                    <cost name="pts" typeId="points" value="0"/>
                    <cost name="Warband Rating" typeId="wb-rating" value="0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="55d2441e-021f-0b95-55d4-57546c0b4fa8" name="Strongman" page="0" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="parent" value="1" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="maxSelections" type="max"/>
                  </constraints>
                  <rules>
                    <rule id="4589cae9-c538-2408-d165-c642682ced49" name="Strongman" page="0" hidden="false">
                      <description>He may use a double-handed weapon without the usual penalty of always striking last. Work out order of battle as you would with other weapons</description>
                    </rule>
                  </rules>
                  <costs>
                    <cost name="pts" typeId="points" value="0"/>
                    <cost name="Warband Rating" typeId="wb-rating" value="0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="1a0a5ba9-5ab3-cff0-d8e7-21861bec2f9a" name="Unstoppable Charge" page="0" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="parent" value="1" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="maxSelections" type="max"/>
                  </constraints>
                  <rules>
                    <rule id="6994fd3a-76ff-d13b-6593-a979947a9f7a" name="Unstoppable Charge" page="0" hidden="false">
                      <description>When he charges, the warrior is almost impossible to halt. He adds +1 to his Weapon Skill when charging.</description>
                    </rule>
                  </rules>
                  <costs>
                    <cost name="pts" typeId="points" value="0"/>
                    <cost name="Warband Rating" typeId="wb-rating" value="0"/>
                  </costs>
                </selectionEntry>
              </selectionEntries>
            </selectionEntryGroup>

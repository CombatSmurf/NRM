          <constraints>
            <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0e4f-1a4d-3a2c-1721" type="max"/>
          </constraints>
          <entryLinks>
            <entryLink id="a0de-558b-75dc-56ba" name="Academic Skills" hidden="false" collective="false" import="true" targetId="f8cb9c64-fd91-ecfd-2e82-5ec10ec7ef53" type="selectionEntryGroup"/>
          </entryLinks>

          </constraints>
          <entryLinks>
            <entryLink id="e77d-869c-f8df-a640" name="Special Skills (Shadow Warrior)" hidden="false" collective="false" import="true" targetId="285ebcd1-3b2e-4937-39bc-a88721067dca" type="selectionEntryGroup"/>
          </entryLinks>

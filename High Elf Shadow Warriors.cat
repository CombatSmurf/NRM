          </costs>
        </selectionEntry>
        <selectionEntry id="b053-9bcf-0403-e200" name="Strength Skills" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f9f1-8973-277d-5126" type="max"/>
          </constraints>
          <entryLinks>
            <entryLink id="fbb0-825a-6000-5cca" name="Strength Skills" hidden="false" collective="false" import="true" targetId="9e76820a-3a93-f94a-a7c7-d31889583e06" type="selectionEntryGroup"/>
          </entryLinks>

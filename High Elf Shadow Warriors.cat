        <selectionEntry id="5d5c6559-2773-1cc5-3835-0eb5869758f2" name="Skills" page="0" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="minSelections" type="min"/>
            <constraint field="selections" scope="parent" value="1" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="maxSelections" type="max"/>
          </constraints>
          <selectionEntryGroups>
            <selectionEntryGroup id="7238c427-6c7e-f37d-8a77-73acf14ada3a" name="Strength Skills (only with Powerful build skill)" hidden="false" collective="false" import="true">
              <selectionEntries>
                <selectionEntry id="ca57804c-dc5d-ef51-7654-c004a6cbbc82" name="Mighty Blow" page="0" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="parent" value="1" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="maxSelections" type="max"/>
                  </constraints>
                  <rules>
                    <rule id="4241b83c-2f1a-019d-78a4-792f268faea4" name="Mighty Blow" page="0" hidden="false">
                      <description>The warrior knows how to use his strength to maximum effect and has a +1 Strength bonus in close combat (excluding pistols). As his
Strength is used for close combat weapons, the bonus applies to all such weapons.</description>
                    </rule>
                  </rules>
                  <costs>
                    <cost name="pts" typeId="points" value="0"/>
                    <cost name="Warband Rating" typeId="wb-rating" value="0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="15eb871e-6a2a-6ed0-4b05-dad3a29cd126" name="Pit Fighter" page="0" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="parent" value="1" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="maxSelections" type="max"/>
                  </constraints>
                  <rules>
                    <rule id="4812e629-a542-e0ff-3edf-a807b1a0773d" name="Pit Fighter" page="0" hidden="false">
                      <description>The warrior has learned how to fight in enclosed spaces from his time in the dangerous fighting pits of the Empire. He is an expert at fighting in confined areas and adds +1 to his WS and +1 to his Attacks if he is fighting inside buildings or ruins.</description>
                    </rule>
                  </rules>
                  <costs>
                    <cost name="pts" typeId="points" value="0"/>
                    <cost name="Warband Rating" typeId="wb-rating" value="0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="b6175506-41cf-ecee-327b-b6fc3ba68316" name="Resilient" page="0" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="parent" value="1" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="maxSelections" type="max"/>
                  </constraints>
                  <rules>
                    <rule id="20d3ff44-676d-e416-1b1b-99a54bd2af24" name="Resilient" page="0" hidden="false">
                      <description>Deduct -1 Strength from all hits against him in close combat. This does not affect armour save modifiers</description>
                    </rule>
                  </rules>
                  <costs>
                    <cost name="pts" typeId="points" value="0"/>
                    <cost name="Warband Rating" typeId="wb-rating" value="0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="aa7cdeb9-4567-73b5-a419-e36147184461" name="Fearsome" page="0" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="parent" value="1" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="maxSelections" type="max"/>
                  </constraints>
                  <rules>
                    <rule id="49745af0-992c-90d3-62fc-8ba807fbbda1" name="Fearsome" page="0" hidden="false">
                      <description>The model that he causes fear in opposing models</description>
                    </rule>
                  </rules>
                  <costs>
                    <cost name="pts" typeId="points" value="0"/>
                    <cost name="Warband Rating" typeId="wb-rating" value="0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="b029e595-f9cb-314f-2095-edb35f44d7d8" name="Strongman" page="0" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="parent" value="1" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="maxSelections" type="max"/>
                  </constraints>
                  <rules>
                    <rule id="29ed13db-686e-51e6-b716-e52779bc8f63" name="Strongman" page="0" hidden="false">
                      <description>He may use a double-handed weapon without the usual penalty of always striking last. Work out order of battle as you would with other weapons</description>
                    </rule>
                  </rules>
                  <costs>
                    <cost name="pts" typeId="points" value="0"/>
                    <cost name="Warband Rating" typeId="wb-rating" value="0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="ecd2b4e7-a5d2-c943-0532-87bcaae48a56" name="Unstoppable Charge" page="0" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="parent" value="1" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="maxSelections" type="max"/>
                  </constraints>
                  <rules>
                    <rule id="6082653c-ccc1-6800-7631-fbea1cb56fc2" name="Unstoppable Charge" page="0" hidden="false">
                      <description>When he charges, the warrior is almost impossible to halt. He adds +1 to his Weapon Skill when charging.</description>
                    </rule>
                  </rules>
                  <costs>
                    <cost name="pts" typeId="points" value="0"/>
                    <cost name="Warband Rating" typeId="wb-rating" value="0"/>
                  </costs>
                </selectionEntry>
              </selectionEntries>
            </selectionEntryGroup>
          </selectionEntryGroups>

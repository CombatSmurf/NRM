          <rules>
            <rule id="a9a369c7-50d9-03e6-602f-9e2d4cc87a93" name="BlackBlood" hidden="false">
              <description>If the model loses a wound in close combat, anyone in base contact with the model suffers a Strength 3 hit (no critical hits) from the spurting corrosive blood.</description>

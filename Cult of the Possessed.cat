        <selectionEntry id="7bb5efcf-16c7-2f2c-1a39-9f085a7eb491" name="Extra Arm" hidden="false" collective="false" import="true" type="upgrade">
          <rules>
            <rule id="82d66311-d137-22f0-1abe-2c905a813304" name="Extra Arm" hidden="false">
              <description>The mutant may use any single-handed weapon in the extra arm, giving him +1 attack when fighting in hand-to-hand combat. Alternatively, he may carry a shield or a buckler in the extra arm. If a Possessed chooses to do this, he gains an extra attack but still cannot carry a weapon.</description>
            </rule>
          </rules>

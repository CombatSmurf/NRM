                  <repeats>
                    <repeat field="selections" scope="5af78c33-7ca0-9880-6da5-eff247bc5de5" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" childId="e6db8828-f3ef-96e2-60f4-43eb9169dd83" repeats="1" roundUp="false"/>

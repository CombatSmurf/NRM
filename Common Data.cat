    <selectionEntry type="upgrade" import="true" name="Mechanical suit" hidden="false" id="2f3a-faba-a17e-2d1e">
      <costs>
        <cost name="pts" typeId="points" value="225"/>
        <cost name="Warband Rating" typeId="wb-rating" value="0"/>
      </costs>
      <rules>
        <rule name="Rarity" id="3509-b90d-b70c-89ae" hidden="false">
          <description>Rarity 14</description>
        </rule>
        <rule name="Spellcasters" id="a38c-4eba-4080-ffc3" hidden="false">
          <description>Chaos Armor does not hinder its wearer from casting spells or rituals.
It can be worn by spellcasters but they cannot combine it with a shield or buckler without appropriate skills.</description>
        </rule>
        <rule name="Chaos Armor" id="f87c-2538-82d5-9ff9" hidden="false">
          <description>A Mechanical suit counts as Chaos armor and rules that would affect Chaos armor affect the suit as well.</description>
        </rule>
        <rule name="Gift of Chaos" id="8612-e9f8-4bb0-6914" hidden="false">
          <description>Chaos Armor is a gift from the Dark Gods to the worthy warrior.
A Hero who has successfully purchased a suit of Chaos Armor will never give it away to another warband member but put it on himself immediately.


Chaos Armor becomes fused to the body of its wearer.
It can never be removed.</description>
        </rule>
        <rule name="Suited and Booted" id="300a-c4bb-cf8b-fc38" hidden="false">
          <description>A Sorcerer equipped with a Mechanical suit receives +3 to Movement.</description>
        </rule>
      </rules>
      <profiles>
        <profile name="Mechanical suit" typeId="94239014-ea28-23eb-4142-f492dc4caf17" typeName="Armor" hidden="false" id="3529-a1fc-b6cc-4f2d">

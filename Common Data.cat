          <description>Rarity 8 (Dwarfs only)</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink name="Cutting edge" hidden="false" type="rule" id="84a8-ae0a-94d1-c16b" targetId="4b68-6905-29fd-e549"/>

    <selectionEntryGroup name="Armor, Chaos Dwarves %" id="4dad-b017-16e1-132b" hidden="false">
      <entryLinks>
        <entryLink import="true" name="Shield, %" hidden="false" id="6c99-c421-d359-9889" type="selectionEntry" targetId="bb4f-ffbc-f928-c76d"/>
        <entryLink import="true" name="Helmet, %" hidden="false" id="fcb9-186c-241e-4bfd" type="selectionEntry" targetId="c138-9c66-20d9-fc8e"/>
        <entryLink import="true" name="Light Armor, %" hidden="false" id="88d2-367e-133f-d36f" type="selectionEntry" targetId="7e46-dc45-605f-2af2"/>
        <entryLink import="true" name="Heavy Armour, %" hidden="false" id="e0e4-e458-24d3-418a" type="selectionEntry" targetId="0fd7-ba59-1775-4a35"/>
        <entryLink import="true" name="Buckler, %" hidden="false" id="b39c-ee56-5da6-44a3" type="selectionEntry" targetId="9d7a-b710-1718-fd19"/>
      </entryLinks>
      <selectionEntries>
        <selectionEntry type="upgrade" import="true" name="Mechanical suit, Discount" hidden="false" id="d9c1-e151-e99a-c24c">
          <costs>
            <cost name="pts" typeId="points" value="112.5"/>
            <cost name="Warband Rating" typeId="wb-rating" value="0"/>
          </costs>
          <rules>
            <rule name="Rarity" id="951b-6a30-38b3-cbd8" hidden="false">
              <description>Rarity 14</description>
            </rule>
            <rule name="Spellcasters" id="f47d-cf80-bcf9-ea2e" hidden="false">
              <description>Chaos Armor does not hinder its wearer from casting spells or rituals.
It can be worn by spellcasters but they cannot combine it with a shield or buckler without appropriate skills.</description>
            </rule>
            <rule name="Chaos Armor" id="dfa4-265d-cc06-a428" hidden="false">
              <description>A Mechanical suit counts as Chaos armor and rules that would affect Chaos armor affect the suit as well.</description>
            </rule>
            <rule name="Gift of Chaos" id="d568-0574-ca60-c37b" hidden="false">
              <description>Chaos Armor is a gift from the Dark Gods to the worthy warrior.
A Hero who has successfully purchased a suit of Chaos Armor will never give it away to another warband member but put it on himself immediately.


Chaos Armor becomes fused to the body of its wearer.
It can never be removed.</description>
            </rule>
            <rule name="Suited and Booted" id="a736-02d3-8527-bc6e" hidden="false">
              <description>A Sorcerer equipped with a Mechanical suit receives +3 to Movement.</description>
            </rule>
          </rules>
          <profiles>
            <profile name="Mechanical suit" typeId="94239014-ea28-23eb-4142-f492dc4caf17" typeName="Armor" hidden="false" id="6792-7fe6-bde9-fc03">
              <characteristics>
                <characteristic name="Armor Save" id="e351-c442-92b5-d5d6" hidden="false" typeId="26f1ea4e-6017-a8fa-db2b-5c2a83aea46b">4+</characteristic>
                <characteristic name="Special" id="9f30-9840-b3b6-beb2" hidden="false" typeId="ff797ec4-8d7e-cab1-656e-896ae3ed005f"/>
              </characteristics>
            </profile>
          </profiles>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup name="Armor, Bretonnia %" id="e3da-829f-ee59-5304" hidden="false">
      <entryLinks>
        <entryLink import="true" name="Shield, %" hidden="false" id="5f9d-16bd-1792-8505" type="selectionEntry" targetId="bb4f-ffbc-f928-c76d"/>
        <entryLink import="true" name="Helmet, %" hidden="false" id="e132-d077-6208-03ea" type="selectionEntry" targetId="c138-9c66-20d9-fc8e"/>
        <entryLink import="true" name="Light Armor, %" hidden="false" id="aa4a-2b86-77a0-86b5" type="selectionEntry" targetId="7e46-dc45-605f-2af2"/>
        <entryLink import="true" name="Heavy Armour, %" hidden="false" id="146f-c635-2826-0944" type="selectionEntry" targetId="0fd7-ba59-1775-4a35"/>
        <entryLink import="true" name="Buckler, %" hidden="false" id="3408-ad63-bab0-686c" type="selectionEntry" targetId="9d7a-b710-1718-fd19"/>
        <entryLink import="true" name="Barding, %" hidden="false" id="da12-0b72-06b0-e9ad" type="selectionEntry" targetId="18cc-7c29-7f0c-f572"/>
      </entryLinks>
      <selectionEntries>
        <selectionEntry type="upgrade" import="true" name="Kite Shield, % (Bret Knights)" hidden="false" id="7aff-27dd-871c-0385">
          <profiles>
            <profile name="Kite Shield" typeId="94239014-ea28-23eb-4142-f492dc4caf17" typeName="Armor" hidden="false" id="0bb7-daa1-44d5-7864">
              <characteristics>
                <characteristic name="Armor Save" typeId="26f1ea4e-6017-a8fa-db2b-5c2a83aea46b">+2 / +1</characteristic>
                <characteristic name="Special" typeId="ff797ec4-8d7e-cab1-656e-896ae3ed005f">Wall of Wood</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink name="Vain" id="14b4-3aa3-2d2f-5b62" hidden="false" type="rule" targetId="da88-e89f-22d3-6135"/>
          </infoLinks>
          <costs>
            <cost name="pts" typeId="points" value="5"/>
            <cost name="Warband Rating" typeId="wb-rating" value="0"/>
          </costs>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Warhorse, %" hidden="false" id="df9d-3f47-0b91-4b9e" page="0" collective="false">
          <profiles>
            <profile name="Warhorse" typeId="e1beaa44-e54d-dd6b-d1f2-446b333c9bb9" typeName="Model" hidden="false" id="4d0d-8b2d-9a02-1a5d" page="0">
              <characteristics>
                <characteristic name="M" typeId="2a0bcc4c-8266-418f-13d6-a6b44def5e92">8</characteristic>
                <characteristic name="WS" typeId="d5aca8ba-0204-b324-b976-c2b536e09924">3</characteristic>
                <characteristic name="BS" typeId="5b4d181b-23ae-5ed7-9262-c1d2f79246a8">0</characteristic>
                <characteristic name="S" typeId="7f1f0a4d-68dc-b0df-5703-c4d0d91a93b9">3</characteristic>
                <characteristic name="T" typeId="54f4796b-dedb-c296-8b1a-ff7f8043293a">3</characteristic>
                <characteristic name="W" typeId="3172c8dc-ebe4-0c40-72ab-8fd0076b9442">1</characteristic>
                <characteristic name="I" typeId="a6fd52b0-be0a-655e-6314-87b392c9c90e">3</characteristic>
                <characteristic name="A" typeId="bf393c37-9d10-fc85-c147-62b1c01a89fe">1</characteristic>
                <characteristic name="LD" typeId="e234eaea-a02a-2fb7-3e1f-605392aabb89">5</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <rules>
            <rule name="Warhorse" id="5dfd-8825-c32e-520e" hidden="false" page="0">
              <description>Only Humans can buy or use warhorses 
You may mount one of your Heroes on a warhorse in the coming battles. Warhorses can only be used if you are back of the book.</description>
            </rule>
            <rule name="Rarity" id="5a35-6c51-4f08-d18e" hidden="false">
              <description>Rarity 11

Only available to Humans.</description>
            </rule>
          </rules>
          <costs>
            <cost name="pts" typeId="points" value="40"/>
            <cost name="Warband Rating" typeId="wb-rating" value="0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="9d72-8c8f-1eba-38dc" name="Characteristic Decreases" hidden="false" collective="false" import="true">
      <entryLinks>
        <entryLink import="true" name="-1 A" hidden="false" id="88f7-4286-98e4-08be" type="selectionEntry" targetId="9faf-d3bf-a2ba-411e"/>
        <entryLink import="true" name="-1 WS" hidden="false" id="fa25-6f50-6ed1-12f8" type="selectionEntry" targetId="ae44-58f4-4440-5777"/>
        <entryLink import="true" name="-1 BS" hidden="false" id="744d-27ad-6047-b822" type="selectionEntry" targetId="0e79-80b9-77e3-fcc9"/>
        <entryLink import="true" name="-1 S" hidden="false" id="e01f-8640-4d4a-55ed" type="selectionEntry" targetId="8e57-5d0b-5279-b4ab"/>
        <entryLink import="true" name="-1 T" hidden="false" id="fe36-bfa6-96ef-56da" type="selectionEntry" targetId="ca62-64c2-488a-f17c"/>
        <entryLink import="true" name="-1 A" hidden="false" id="8f4b-d22d-b55a-24ac" type="selectionEntry" targetId="9faf-d3bf-a2ba-411e"/>
        <entryLink import="true" name="-1 LD" hidden="false" id="c93a-97fc-5540-6f87" type="selectionEntry" targetId="a519-13dc-1b04-e39e"/>
        <entryLink import="true" name="-1 I" hidden="false" id="5f27-a6d5-7866-68a6" type="selectionEntry" targetId="7531-eebe-fabf-7cf5"/>
        <entryLink import="true" name="-1 M" hidden="false" id="0fe3-f930-4514-381d" type="selectionEntry" targetId="7dee-74f8-7707-ce64"/>
      </entryLinks>

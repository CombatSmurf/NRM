    <selectionEntry type="upgrade" import="true" name="Dark Elf Blade" hidden="false" id="f009-768d-cd97-e4d6">
      <profiles>
        <profile name="Dark Elf Blade" typeId="9db87680-6ee5-b46c-48ca-dcd1c5de1bad" typeName="HtH Weapon" hidden="false" id="4080-4d17-b7a6-71ce">
          <characteristics>
            <characteristic name="Str" typeId="f10cfcb7-b71e-4c27-9836-75d341e28f68">As User</characteristic>
            <characteristic name="Special" typeId="80dd3fd5-3811-af0b-e182-2ecbc7ad5d8e">Dark Elf Blades are forged in the city of Hag  Graef, the Dark Crag. They are fashioned from combat. Blacksteel, a rare form of steel found deep within the mountains around the city. Dark Elf Blades have wicked protrusions and serrated, which inflict serious damage on an opponent. Any Dark Elf can upgrade a sword or dagger to a Dark Elf blade by paying an additional 20 gc at the time of purchase. Weapons upgraded to a Dark Elf Blade retain  all of their abilities (ie. swords can parry, daggers grant an armour save of 6+).</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <rules>
        <rule name="Critical Damage" id="95c3-472a-31b6-3443" hidden="false">
          <description>Dark Elf blades inflict serious damage on their opponents, when rolling on the critical hit chart a Dark Elf blade will add +1 to the result.</description>
        </rule>
        <rule name="Wicked Edge" id="6626-b073-f29f-7159" hidden="false">
          <description>Dark Elf blades are set with sharp protrusions and serrated edges which inflict serious damage on an opponent, a roll of 2-4 on the injury table is a Stunned result.</description>
        </rule>
        <rule name="Rarity" id="1328-38d5-b960-7103" hidden="false">
          <description>Rarity 9</description>
        </rule>
      </rules>
      <costs>
        <cost name="pts" typeId="points" value="20"/>
        <cost name="Warband Rating" typeId="wb-rating" value="0"/>
      </costs>
    </selectionEntry>

        <profile id="4bd1-fe99-7649-1966" name="Blunderbuss" page="0" hidden="false" typeId="c4b0233c-e5d1-2b41-3446-45a745fbbbec" typeName="Ranged Weapon">
          <characteristics>
            <characteristic name="Range" typeId="a275054b-9b3d-9e68-49e9-7fbb6c714412">16x1</characteristic>
            <characteristic name="Str" typeId="0e9e02bf-4d20-7ac3-d67f-67172b142b5c">3</characteristic>
            <characteristic name="Special" typeId="fde90816-abbb-f019-75a0-0c24662facf3">Fire Once.
Shot.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <rules>
        <rule id="1410-f495-ed2e-283d" name="Shot" hidden="false">
          <description>When your model fires the blunderbuss, draw a line 16&quot; long and 1&quot; wide in any direction from the firer (the line must be absolutely straight).
Any and all models in its path are automatically hit by a Strength 3 hit.</description>
        </rule>
        <rule id="c056-add8-f908-3be6" name="Fire Once" hidden="false">
          <description>It takes a very long time to load a blunderbuss so it may only be fired it once per battle.</description>
        </rule>
        <rule id="bcb7-e625-5f8f-2939" name="Rarity" hidden="false">
          <description>Rarity 9</description>
        </rule>
      </rules>
      <costs>
        <cost name="pts" typeId="points" value="30"/>
        <cost name="Warband Rating" typeId="wb-rating" value="0"/>
      </costs>
    </selectionEntry>

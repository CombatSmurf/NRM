    <selectionEntry id="0ade-8ef6-1f30-29d0" name="Sun Gauntlet" hidden="false" collective="false" import="true" type="upgrade">
      <profiles>
        <profile id="809b-d7af-b338-d4c3" name="Sun Gauntlet" hidden="false" typeId="c4b0233c-e5d1-2b41-3446-45a745fbbbec" typeName="Ranged Weapon">
          <characteristics>
            <characteristic name="Range" typeId="a275054b-9b3d-9e68-49e9-7fbb6c714412">12</characteristic>
            <characteristic name="Str" typeId="0e9e02bf-4d20-7ac3-d67f-67172b142b5c">4</characteristic>
            <characteristic name="Special" typeId="fde90816-abbb-f019-75a0-0c24662facf3">Accurate, No save, Hand to Hand</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <rules>
        <rule id="ef11-b2f4-d2ee-d616" name="Rarity" hidden="false">
          <description>Rarity 12</description>
        </rule>
        <rule id="675e-2232-2db4-2b23" name="Hand-to-hand" hidden="false">
          <description>The Sun Gauntlet can be used with another close combat weapon in hand-to-hand combat with Strength 4 and no armour save.

Because it does not require prepared shot, this bonus attack may be used in each turn of combat.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="a242-408e-c73e-8fd8" name="Accurate" hidden="false" targetId="1609-b4a3-7b97-a719" type="rule"/>

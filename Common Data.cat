    <selectionEntry id="1478-15cf-1d4e-3e13" name="Sigmarite Warhammer (Sisters only)" page="0" hidden="false" collective="false" import="true" type="upgrade">
      <profiles>
        <profile id="fdf9-610c-e8fc-eaf8" name="Sigmarite Warhammer" page="0" hidden="false" typeId="9db87680-6ee5-b46c-48ca-dcd1c5de1bad" typeName="HtH Weapon">
          <characteristics>
            <characteristic name="Str" typeId="f10cfcb7-b71e-4c27-9836-75d341e28f68">+1</characteristic>
            <characteristic name="Special" typeId="80dd3fd5-3811-af0b-e182-2ecbc7ad5d8e">Concussion, Holy Weapon</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <rules>
        <rule id="1f10-7bce-3349-758f" name="Holy Weapon" page="0" hidden="false">
          <description>The warhammer has a +1 bonus on all to wound rolls against any Possessed or Undead models.
Note that you will still need to score a 6 before any modifiers in order to cause a critical hit.

Only Matriarchs and Sister Superiors may carry two Sigmarite  warhammers.</description>
        </rule>
      </rules>
      <infoLinks>

    <selectionEntry id="993b-b4c4-118f-3ce3" name="Claw of the Old Ones" hidden="false" collective="false" import="true" type="upgrade">
      <profiles>
        <profile id="2095-a1c0-3e5e-ae50" name="Claw of the Old Ones" hidden="false" typeId="9db87680-6ee5-b46c-48ca-dcd1c5de1bad" typeName="HtH Weapon">
          <characteristics>
            <characteristic name="Str" typeId="f10cfcb7-b71e-4c27-9836-75d341e28f68">+1</characteristic>
            <characteristic name="Special" typeId="80dd3fd5-3811-af0b-e182-2ecbc7ad5d8e">No save, Parry</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <rules>
        <rule id="0660-4d1b-0f1e-96f0" name="Claw of the Old Ones" hidden="false">
          <description>This is a very ancient weapon made from a strange metal that is impervious to age and corrosion.
The powers of this artefact can only be unleashed through a ritual known only to a handful of Amazons.
The blade of this weapon glows white hot and can cut through armour as if it were paper.</description>
        </rule>
        <rule id="7ff0-e0d8-d441-627c" name="Rarity" hidden="false">
          <description>Rarity 12</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="a5e9-fc74-289d-521f" name="Ignores Armor" hidden="false" targetId="1f6d-8599-e2d3-1062" type="rule"/>
        <infoLink id="f7cd-5e9e-f946-ef2f" name="Parry" hidden="false" targetId="17dc-9c49-08e1-af45" type="rule"/>
      </infoLinks>
      <costs>
        <cost name="pts" typeId="points" value="30"/>
      </costs>
    </selectionEntry>

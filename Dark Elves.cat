      <rules>
        <rule id="544d-9525-7b7f-22fb" name="Animal" hidden="false">
          <description>Cold One Beasthounds are animals and all animal rules apply to them, they never gain experiance.</description>
        </rule>
        <rule id="7b04-e5d2-0ed7-00f8" name="Scaly Skin" hidden="false">
          <description>Cold One Beasthounds have tough scaly skin, and are considered to have a 6+ armour save. This save cannot be modified beyond 6 due to strength modifiers but any result of &apos;no save&apos; on the injury chart will negate the unmodified 6+.</description>
        </rule>
      </rules>

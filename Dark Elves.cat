      <entryLinks>
        <entryLink id="f941a52c-a11a-fef5-dd80-d7a857d3789a" name="Dark Elf Magic" hidden="false" collective="false" import="true" targetId="5cce5525-3057-85be-427a-ceeac0d35c53" type="selectionEntryGroup"/>

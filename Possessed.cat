          <rules>
            <rule id="e7478647-7ac7-fe6e-6b14-077e2b2c12f9" name="Great Claw" hidden="false">
              <description>He may carry no weapons in this arm, but gains an extra attack in hand-to-hand combat with a +1 Strength bonus.</description>
            </rule>
          </rules>
          <selectionEntries>
            <selectionEntry id="cc94611c-ceaf-3170-050c-eb162e358d16" name="First Mutation Discount" hidden="false" collective="false" import="true" type="upgrade">

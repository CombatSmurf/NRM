        <selectionEntry id="5af78c33-7ca0-9880-6da5-eff247bc5de5" name="Spines" hidden="false" collective="false" import="true" type="upgrade">
          <rules>
            <rule id="bd85a204-0692-6d2b-25a3-1f84c5e11470" name="Spines" hidden="false">
              <description>Any model in base contact with the mutant suffers an automatic Strength 1 hit at the beginning of each close combat phase. Spines will never cause critical hits.</description>

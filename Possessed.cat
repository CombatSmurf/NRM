        <selectionEntry id="8807cd84-31f4-7031-3c0b-8cfca60a9588" name="Scorpion Tail" hidden="false" collective="false" import="true" type="upgrade">
          <rules>
            <rule id="909490af-c54c-7964-7d37-d4b056bff4dc" name="Scorpion Tail" hidden="false">
              <description>The mutant has a long barbed tail with a venomed tip, allowing him to make an extra Strength 5 attack in each hand-to-hand combat phase. If the model hit by the tail is immune to poison, the Strength of the hit is reduced to 2.</description>
            </rule>
          </rules>
          <selectionEntries>
            <selectionEntry id="afe5a0bd-60da-56a3-7c3a-a934a61ff1ac" name="First Mutation Discount" hidden="false" collective="false" import="true" type="upgrade">
              <modifiers>
                <modifier type="decrement" field="points" value="40">
                  <repeats>
                    <repeat field="selections" scope="8807cd84-31f4-7031-3c0b-8cfca60a9588" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" childId="afe5a0bd-60da-56a3-7c3a-a934a61ff1ac" repeats="1" roundUp="false"/>

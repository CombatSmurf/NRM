    <selectionEntryGroup id="5b051df2-86a2-4480-25d1-a99dcbed79b0" name="Necromancy" hidden="false" collective="false" import="true" sortIndex="2" flatten="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="minSelections" type="min"/>
        <constraint field="selections" scope="parent" value="-1" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="maxSelections" type="max"/>
        <constraint field="selections" scope="force" value="0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="minInForce" type="min"/>
        <constraint field="selections" scope="force" value="-1" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="maxInForce" type="max"/>
        <constraint field="selections" scope="roster" value="0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="minInRoster" type="min"/>
        <constraint field="selections" scope="roster" value="-1" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="maxInRoster" type="max"/>
        <constraint field="points" scope="parent" value="0" percentValue="false" shared="false" includeChildSelections="true" includeChildForces="false" id="minPoints" type="min"/>
        <constraint field="points" scope="parent" value="-1" percentValue="false" shared="false" includeChildSelections="true" includeChildForces="false" id="maxPoints" type="max"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="0c3ddff7-96d2-9cfb-74c5-b7171d3e7088" name="1 Life Stealer" page="0" hidden="false" collective="false" import="true" type="upgrade">
          <profiles>
            <profile id="a725-5766-c812-77e7" name="1 Life Stealer" hidden="false" typeId="d891-ee2b-b7dc-f545" typeName="Magic">
              <characteristics>
                <characteristic name="Difficulty" typeId="dd91-3f4d-8b72-7905">10</characteristic>
                <characteristic name="Effect" typeId="0592-3510-8508-7263">Chose a model within 6&quot; inches.
It suffers a wound with no save, and the caster gains an extra wound for the duration of the battle.
Can take it above maxiumums.
Can not be cast on undead or  possessed.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="0"/>
            <cost name="Warband Rating" typeId="wb-rating" value="0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="d1f76c6a-5d40-475e-b3d7-c1f561cadb2b" name="2 Re-animatiom" page="0" hidden="false" collective="false" import="true" type="upgrade">
          <profiles>
            <profile id="c8e2-c6c8-4e71-000b" name="2 Re-animatiom" hidden="false" typeId="d891-ee2b-b7dc-f545" typeName="Magic">
              <characteristics>
                <characteristic name="Difficulty" typeId="dd91-3f4d-8b72-7905">5</characteristic>
                <characteristic name="Effect" typeId="0592-3510-8508-7263">One Zombie that went out of action on the lasts hand to hand or shooting phase imediatly returns to battle.
Place the model within 6&quot; of the necromancer. It can not be placed in direct hand to hand combat.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="0"/>
            <cost name="Warband Rating" typeId="wb-rating" value="0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="f92e62c0-8650-3149-1d9c-cb6745a3af63" name="3 Death Vision" page="0" hidden="false" collective="false" import="true" type="upgrade">
          <profiles>
            <profile id="64e9-fdd8-fe9b-5303" name="3 Death Vision" hidden="false" typeId="d891-ee2b-b7dc-f545" typeName="Magic">
              <characteristics>
                <characteristic name="Difficulty" typeId="dd91-3f4d-8b72-7905">6</characteristic>
                <characteristic name="Effect" typeId="0592-3510-8508-7263">The necromancer causes fear for the duration of the battle.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="0"/>
            <cost name="Warband Rating" typeId="wb-rating" value="0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="7cd61a42-3f3a-76c4-976c-213a477b3dc9" name="4 Spell of Doom" page="0" hidden="false" collective="false" import="true" type="upgrade">
          <profiles>
            <profile id="e90f-4ee8-2417-8cdd" name="4 Spell of Doom" hidden="false" typeId="d891-ee2b-b7dc-f545" typeName="Magic">
              <characteristics>
                <characteristic name="Difficulty" typeId="dd91-3f4d-8b72-7905">9</characteristic>
                <characteristic name="Effect" typeId="0592-3510-8508-7263">Chose 1 model within 12&quot; of the caster.
They must test strength.
If they fail they get an imediate check on the injury table.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="0"/>
            <cost name="Warband Rating" typeId="wb-rating" value="0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="2431affd-9208-e7c0-f831-f188f49fc5e9" name="5 Call of Vanhel" page="0" hidden="false" collective="false" import="true" type="upgrade">
          <profiles>
            <profile id="2272-424e-97ea-2239" name="5 Call of Vanhel" hidden="false" typeId="d891-ee2b-b7dc-f545" typeName="Magic">
              <characteristics>
                <characteristic name="Difficulty" typeId="dd91-3f4d-8b72-7905">6</characteristic>
                <characteristic name="Effect" typeId="0592-3510-8508-7263">One direwolf or zombie within 6&quot; of the necromacer can move for free.
If they move into base to base contact with an enemy, it counts as having charged.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="0"/>
            <cost name="Warband Rating" typeId="wb-rating" value="0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="490cd705-4fd2-9c5b-56aa-e2fadb325281" name="6 Spell Of Awakening" page="0" hidden="false" collective="false" import="true" type="upgrade">
          <profiles>
            <profile id="4842-91a3-1fe4-7ff7" name="6 Spell Of Awakening" hidden="false" typeId="d891-ee2b-b7dc-f545" typeName="Magic">
              <characteristics>
                <characteristic name="Difficulty" typeId="dd91-3f4d-8b72-7905">Auto</characteristic>
                <characteristic name="Effect" typeId="0592-3510-8508-7263">If a enemey hero is killed in battle, (an 11-16 on the serious injury chart) the necromancer may raise him as a zombie.

He is a henchmen that retains all equpiment and characteristics, but can not be armed with anything else, has no skills and can gain no more experience.
He is a normal zombie in all other respects.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="points" value="0"/>
            <cost name="Warband Rating" typeId="wb-rating" value="0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>

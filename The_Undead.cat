      <rules>
        <rule id="afe2-4995-4d79-6d88" name="Unliving" hidden="false">
          <description>Dire Wolves do not gain experience.
You can’t teach an old dog new tricks!</description>
        </rule>
        <rule id="a859-2a3a-d402-d059" name="Charge" hidden="false">
          <description>Dire Wolves are slavering creatures that overpower their opponents when they charge.
Dire Wolves fight with 2 attacks instead of 1 during the turn they charge.</description>
        </rule>
      </rules>

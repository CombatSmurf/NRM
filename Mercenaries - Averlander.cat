      <rules>
        <rule id="ced7-694f-6083-4c01" name="Promotion" hidden="false">
          <description>A Halfling that is promoted to hero through the “The lad’s got talent” advance may not choose Strength skills as one of his two skill lists.
Halflings are not known for their great strength!</description>
        </rule>
      </rules>

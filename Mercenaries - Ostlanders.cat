      <rules>
        <rule id="e92b-6d88-7648-d55c" name="Slow Witted" hidden="false">
          <description>Although Ogres are capable of earning experience and bettering themselves they are not the smartest of creatures.

Ogres only gain advances at half the rate of everyone else (ie, they must accrue twice as much experience as normal to get an advance).</description>
        </rule>
      </rules>

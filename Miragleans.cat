      <costs>
        <cost name="pts" hidden="false" id="c393-12e6-5bb0-b2e6" typeId="points" value="35"/>
        <cost name="Warband Rating" hidden="false" id="bb3a-499c-f5a6-b34f" typeId="wb-rating" value="5"/>

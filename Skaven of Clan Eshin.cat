            <entryLink import="true" name="Free Dagger" hidden="false" id="6d72-604f-5c83-00d2" type="selectionEntry" targetId="0d0b-ed37-d8b0-4cbf"/>
            <entryLink import="true" name="Flail" hidden="false" id="d112-91e8-1c1d-c351" type="selectionEntry" targetId="fea6-684b-02c4-6c62"/>

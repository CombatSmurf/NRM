            <entryLink import="true" name="Sling" hidden="false" id="10ff-7ce2-17d5-3ccd" type="selectionEntry" targetId="87c7-49b5-f1e7-6662"/>
            <entryLink import="true" name="Throwing Knives/Stars" hidden="false" id="c8f9-a91d-c2a6-5bd8" type="selectionEntry" targetId="23f5-19c3-5a6c-a8fb"/>
